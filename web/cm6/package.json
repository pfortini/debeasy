{
  "name": "debeasy-cm6",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Bundled CodeMirror 6 entry for debeasy. Output is committed to web/static/vendor/cm6.bundle.js so go build alone produces the binary.",
  "scripts": {
    "build": "esbuild entry.js --bundle --minify --format=iife --global-name=DebeasyCM --outfile=../static/vendor/cm6.bundle.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-sql": "^6.7.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
